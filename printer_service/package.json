{
  "name": "kicardapio-printer",
  "version": "2.0.0",
  "description": "Agente de Impressão KiCardápio - ESC/POS + PDF",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder build --win --publish never",
    "build:dir": "electron-builder build --win --dir --publish never"
  },
  "author": "KiCardápio",
  "license": "ISC",
  "dependencies": {
    "body-parser": "^1.20.3",
    "cors": "^2.8.5",
    "express": "^4.21.2",
    "pdf-to-printer": "^5.7.0"
  },
  "devDependencies": {
    "electron": "^31.0.0",
    "electron-builder": "^24.13.3",
    "png-to-ico": "^3.0.1",
    "sharp": "^0.34.5"
  },
  "build": {
    "appId": "com.kicardapio.printer",
    "productName": "KiCardapio Printer",
    "directories": {
      "output": "release"
    },
    "files": [
      "main.js",
      "server.js",
      "index.html",
      "icon.png",
      "icon.ico",
      "!node_modules/**/*.md",
      "!node_modules/**/*.d.ts",
      "!node_modules/**/test",
      "!node_modules/**/tests",
      "!node_modules/**/.github",
      "!node_modules/**/example",
      "!node_modules/**/examples"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": true,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "KiCardápio Impressão",
      "uninstallDisplayName": "KiCardápio Impressão",
      "installerIcon": "icon.ico",
      "uninstallerIcon": "icon.ico",
      "installerHeaderIcon": "icon.ico"
    },
    "asar": true,
    "asarUnpack": [
      "node_modules/pdf-to-printer"
    ]
  }
}
